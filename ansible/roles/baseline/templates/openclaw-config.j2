{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "{{ ollama_base_url }}",
        "apiKey": "ollama-local",
        "api": "openai-responses",
        "models": [
          {
            "id": "llama3.2:3b",
            "name": "Llama 3.2 3B",
            "contextWindow": 32768,
            "maxTokens": 8192
          },
          {
            "id": "qwen3:14b",
            "name": "Qwen3 14B",
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/{{ default_model }}"
      }
    }
  },
  "channels": {
    "telegram": {
      "token": "{{ telegram_bot_token }}",
      "allowFrom": ["{{ telegram_chat_id }}"]
    }
  }
}
